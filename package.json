{
  "name": "mai_ds_2",
  "version": "1.0.0",
  "description": "Website for the Museum of Artificial Intelligence (aimuseum.se)",
  "scripts": {
    "start": "node start-server.js",
    "build": "npm run build:static && npm run build:pages && npm run build:css && npm run build:daily",
    "build:static": "node tools/build-static.js",
    "build:pages": "node tools/build-pages.js",
    "build:css": "postcss src/tailwind.css -o public/assets/css/tailwind.css --env production",
    "build:daily": "node tools/inject-daily.js",
    "serve": "node server/server.js",
    "optimize": "node tools/optimize-images.js src/site/images/slide",
    "generate:slides": "node tools/generate-slides-manifest.js",
    "slides:add": "node tools/slides-add.js",
    "slides:remove": "node tools/slides-remove.js",
    "audit": "lighthouse http://localhost:3000 --output=json --output-path=reports/lighthouse.json",
    "test": "node agent/test/notice.test.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "autoprefixer": "^10.4.16",
    "lighthouse": "^12.0.0",
    "postcss": "^8.4.31",
    "postcss-cli": "^10.1.0",
    "sharp": "^0.33.4",
    "tailwindcss": "^3.4.4"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "dotenv": "^16.6.1",
    "express": "^4.19.2"
  },
  "directories": {
    "doc": "docs"
  }
}
